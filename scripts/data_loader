import torch
from torch.utils.data import DataLoader
from dataset import ChestXrayDataset


def get_dataloaders(config):
    train_dataset = ChestXrayDataset(config.train_path)
    val_dataset   = ChestXrayDataset(config.val_path)
    test_dataset  = ChestXrayDataset(config.test_path)

    train_loader = DataLoader(
        train_dataset,
        batch_size=config.batch_size,
        shuffle=True,
        num_workers=config.num_workers,
        pin_memory=True
    )

    val_loader = DataLoader(
        val_dataset,
        batch_size=config.batch_size,
        shuffle=False,
        num_workers=config.num_workers,
        pin_memory=True
    )

    test_loader = DataLoader(
        test_dataset,
        batch_size=config.batch_size,
        shuffle=False,
        num_workers=config.num_workers,
        pin_memory=True
    )

    return train_loader, val_loader, test_loader